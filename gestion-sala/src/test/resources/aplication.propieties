# Base de datos en memoria H2 para los tests unitarios — No requiere MySQL activo
spring.datasource.url=jdbc:h2:mem:testdb;DB_CLOSE_DELAY=-1;MODE=MySQL
spring.datasource.driver-class-name=org.h2.Driver
spring.datasource.username=sa
spring.datasource.password=
spring.jpa.hibernate.ddl-auto=create-drop
spring.jpa.database-platform=org.hibernate.dialect.H2Dialect
spring.jpa.show-sql=false

# URLs Ficticias para Feign durante el entorno de pruebas de Salas
# (Ajusta los servicios a los que se conecta Gestión de Sala, por ejemplo, Asistencia)
asistencia.service.url=http://localhost:8080
estudiantes.service.url=http://localhost:8081

# Desactivar validadores de compatibilidad de Spring Cloud en ejecución de tests
spring.cloud.compatibility-verifier.enabled=false

