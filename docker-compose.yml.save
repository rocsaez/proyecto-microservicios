version: '3.8'

services:
  # 1. Base de Datos Centralizada (según tu configuración actual)
  mysql_servidor:
    image: mysql:8
    container_name: mysql_servidor
    environment:
      MYSQL_ROOT_PASSWORD: password_seguro_123
      MYSQL_DATABASE: universidad_backend
    ports:
      - "3306:3306"
    # Importante: Usa volúmenes para que no se borren tus datos
    volumes:
      - proyecto_persistencia_db:/var/lib/mysql

  # 2. Gestión Estudiante
  gestion-estudiante:
    build: ./gestion-estudiante
    container_name: ms-estudiante
    ports:
      - "8081:8081"
    depends_on:
      - mysql_servidor

  # 3. Gestión Profesor
  gestion-profesor:
    build: ./gestion-profesor
    container_name: ms-profesor
    ports:
      - "8082:8082"
    depends_on:
      - mysql_servidor

  # 4. Sistema Biblioteca
  sistema-biblioteca:
    build: ./sistema-biblioteca
    container_name: ms-biblioteca
    ports:
      - "8083:8083"
    depends_on:
      - mysql_servidor

  # 5. Sistema Inscripción (Puerto 8085 según tu lista)
  sistema-inscripcion:
    build: ./sistema-inscripcion
    container_name: ms-inscripcion
    ports:
      - "8085:8085"
    depends_on:
      - mysql_servidor

  # 6. Beneficio / Beca (Ajustado con build)
  sistema-becas:
    build: ./beca  # Verificado según tu carpeta en VS Code
    container_name: ms-becas
    ports:
      - "8086:8086"
    
